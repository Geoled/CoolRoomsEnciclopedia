      else if (card.classList.contains('food-card')) t = 'foods';
      openView(t, card.dataset.id);
    });
  });
}

// ── Delete ─────────────────────────────────────
async function deleteItem(type, obj) {
  const folder = type;
  const filename = `${folder}/${type}_${obj.id}.json`;
  const url = `${API.base()}/${filename}`;
  const token = API.token();
  if (!token) { toast('Настройте GitHub токен', 'error'); return; }
  let sha = obj._sha || null;
  if (!sha) {
    try {
      const resp = await fetch(url, { headers: { Authorization: `token ${token}` } });
      if (resp.ok) { const info = await resp.json(); sha = info.sha; }
      else if (resp.status === 404) { toast('Файл не найден на GitHub', 'error'); return; }
    } catch(e) { toast('Ошибка сети', 'error'); return; }
  }
  if (!sha) { toast('Не удалось получить SHA файла', 'error'); return; }
  const delResp = await fetch(url, {
    method: 'DELETE',
    headers: { Authorization: `token ${token}` }
  });
  if (!delResp.ok) {
    toast('Ошибка удаления с GitHub', 'error');
    return;
  }
  data[type] = data[type].filter(o => !idsMatch(o.id, obj.id));
  closeView();
  toast(`"${obj.title||obj.name}" удалён`, 'success');
  renderTree();
  renderContent();
}

