// ── GitHub API ────────────────────────────────
async function fetchFileIndex(folder) {
  if (!API.owner() || !API.repo()) return [];
  const url = `${API.base()}/${folder}`;
  try {
    const resp = await fetch(url, { headers: API.headers(), cache: 'no-store' });
    if (!resp.ok) return [];
    const items = await resp.json();
    const files = Array.isArray(items)
      ? items.filter(f => f.type === 'file' && f.name.endsWith('.json'))
      : [];
    fileIndexCache[folder] = files.map(f => ({ name: f.name, sha: f.sha, download_url: f.download_url }));
    return fileIndexCache[folder];
  } catch(e) { return []; }
}

async function loadSectionData(section) {
  const folder = section;
  const files = await fetchFileIndex(folder);
  const arr = [];
  await Promise.all(files.map(file =>
    fetch(file.download_url, { cache: 'no-store' })
      .then(r => r.ok ? r.json() : null)
      .then(obj => {
        if (obj) { obj._sha = file.sha; obj._folder = folder; arr.push(obj); }
      })
      .catch(() => {})
  ));
  arr.forEach(obj => {
    if (section === 'levels') ensureStats(obj, {safety:3,stability:3,entities:3,resources:3,mental:3,navigation:3});
    else if (section === 'entities') ensureStats(obj, {danger:3,frequency:3,intelligence:3,aggression:3});
    else if (section === 'items') ensureStats(obj, {weight:3,rarity:3,usefulness:3,durability:3});
    else if (section === 'foods') ensureStats(obj, {calories:500,availability:5,taste:3,shelfLife:7});
    if (section === 'levels') {
      if (!Array.isArray(obj.ent)) obj.ent = [];
      if (!Array.isArray(obj.foodIds)) obj.foodIds = [];
      if (!Array.isArray(obj.itemIds)) obj.itemIds = [];
    }
  });
  data[section] = arr;
}

async function loadAllData() {
  const sections = ['levels','entities','items','foods'];
  const loading = showLoading(contentArea);
  await Promise.all(sections.map(s => loadSectionData(s)));
  hideLoading(loading);
}

async function commitFile(filename, contentObj, oldSha) {
  const token = API.token();
  if (!token) { toast('Настройте GitHub токен в настройках', 'error'); return false; }
  const url = `${API.base()}/${filename}`;
  let sha = oldSha || null;
  if (!sha) {
    try {
      const r = await fetch(url, { headers: { Authorization: `token ${token}` } });
      if (r.ok) { const info = await r.json(); sha = info.sha; }
    } catch(e) {}
  }
  const jsonStr = JSON.stringify(contentObj, null, 2);
  const body = {
    message: `Update ${filename}`,
    content: b64Encode(jsonStr),
    branch: 'main'
  };
  if (sha) body.sha = sha;
  try {
    const resp = await fetch(url, {
      method: 'PUT',
      headers: { Authorization: `token ${token}`, 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
    if (!resp.ok) {
      const err = await resp.json().catch(() => ({}));
      toast(err.message || 'Ошибка сохранения', 'error');
      return false;
    }
    return true;
  } catch(e) { toast('Сетевая ошибка при сохранении', 'error'); return false; }
}

async function uploadImageToRepo(file) {
  const token = API.token();
  if (!token) { toast('Настройте GitHub токен', 'error'); return null; }
  const filename = `images/${Date.now()}_${file.name.replace(/[^a-zA-Z0-9._-]/g, '_')}`;
  const url = `${API.base()}/${filename}`;
  return new Promise((resolve) => {
    const reader = new FileReader();
    reader.onload = async () => {
      const base64 = reader.result.split(',')[1];
      const body = { message: `Upload ${filename}`, content: base64, branch: 'main' };
      try {
        const resp = await fetch(url, {
          method: 'PUT',
          headers: { Authorization: `token ${token}`, 'Content-Type': 'application/json' },
          body: JSON.stringify(body)
        });
        if (resp.ok) {
          const d = await resp.json();
          resolve(d.content.download_url);
        } else {
          toast('Ошибка загрузки изображения', 'error');
          resolve(null);
        }
      } catch(e) { resolve(null); }
    };
    reader.readAsDataURL(file);
  });
}

// ── Rendering ──────────────────────────────────
function renderStatsHTML(stats, labels, colors) {
  return Object.entries(labels).map(([key, label]) => {
    const val = stats[key] || 0;
    const maxVal = key === 'calories' ? 2000 : key === 'shelfLife' ? 365 : (key === 'availability' ? 10 : 5);
    const pct = Math.min(100, (val / maxVal) * 100);
    const color = colors[key] || '#777';
    return `<div class="stat-row">
      <span class="stat-label-mini">${label}</span>
      <div class="stat-bar"><div class="stat-fill" style="width:${pct}%;background:${color};"></div></div>
      <span class="stat-value">${val}${key==='calories'?' ккал':key==='shelfLife'?' дн':''}</span>
    </div>`;
  }).join('');
}

function renderCards(items, type) {
  return items.map(obj => {
    const thumb = obj.thumbnail
      ? `<img class="card-img" src="${obj.thumbnail}" loading="lazy" onerror="this.style.display='none'" alt="">`
      : `<div class="card-img" style="display:flex;align-items:center;justify-content:center;color:var(--text-dim);font-size:2.5rem;">${getClassIcon(type, obj.cls)}</div>`;
    let statsHtml = '';
    if (type === 'levels') statsHtml = renderStatsHTML(obj.stats, {safety:'Безопасность',stability:'Стабильность',entities:'Заселённость',resources:'Ресурсы',mental:'Психика',navigation:'Навигация'}, statColors);
    else if (type === 'entities') statsHtml = renderStatsHTML(obj.stats, {danger:'Опасность',frequency:'Частота',intelligence:'Интеллект',aggression:'Агрессия'}, statColors);
    else if (type === 'items') statsHtml = renderStatsHTML(obj.stats, {weight:'Вес',rarity:'Редкость',usefulness:'Полезность',durability:'Прочность'}, statColors);
    else if (type === 'foods') statsHtml = renderStatsHTML(obj.stats, {calories:'Насыщение',availability:'Доступность',taste:'Вкус',shelfLife:'Хранение'}, statColors);
    const dateStr = obj.discoveredAt ? `<div class="card-date">📅 ${obj.discoveredAt}</div>` : '';
    const title = obj.title || obj.name || 'Без названия';
    return `<div class="card" data-type="${type}" data-id="${strId(obj.id)}">
      ${thumb}
      <div class="card-header"><span class="card-id">${obj.id}</span><span class="class-icon">${getClassIcon(type, obj.cls)}</span></div>
      <div style="font-weight:600;font-size:0.95rem;">${title}</div>
      <div style="margin:0.3rem 0;">${statsHtml}</div>
      <div class="card-desc">${(obj.desc||'').substring(0, 90)}${(obj.desc||'').length>90?'...':''}</div>
      <div style="margin-top:0.3rem;">${(obj.tags||[]).map(t => `<span class="tag" data-tag="${t}">${t}</span>`).join('')}</div>
      ${dateStr}
    </div>`;
  }).join('');
}

function renderTagCloud() {
  const allTags = new Map();
  ['levels','entities','items','foods'].forEach(type => {
    data[type].forEach(obj => {
      (obj.tags||[]).forEach(tag => {
        allTags.set(tag, (allTags.get(tag)||0) + 1);
      });
    });
  });
  if (allTags.size === 0) return '';
  const sorted = [...allTags.entries()].sort((a,b) => b[1]-a[1]).slice(0, 25);
  return `<div style="margin:2rem 0;">
    <h4 style="color:var(--gold-dim);margin-bottom:0.5rem;text-align:center;">Облако тегов</h4>
    <div class="tag-cloud">
      ${sorted.map(([tag, count]) => `<span class="tag" data-tag="${tag}" style="font-size:${0.72 + count*0.04}rem;">${tag} (${count})</span>`).join('')}
    </div>
  </div>`;
}

function renderLinkedCards(items, type, label) {
  if (!items.length) return '';
  const cards = items.map(item => `
    <div class="${type}-card" data-id="${strId(item.id)}">
      ${item.thumbnail ? `<img src="${item.thumbnail}" loading="lazy" onerror="this.style.display='none'" alt="">` : '<div style="width:80px;height:80px;background:var(--surface2);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">'+getClassIcon(type==='entity'?'entities':type==='food'?'foods':'levels',item.cls||'0')+'</div>'}
      <div class="${type}-card-name">${item.title || item.name}</div>
    </div>
  `).join('');
  return `<div class="view-section"><h3>${label}</h3><div style="display:flex;flex-wrap:wrap;">${cards}</div></div>`;
}

// ── Dropdown Component ────────────────────────
function createDropdownSync(containerEl, items, selectedIdsArr, placeholder) {
  let selected = [...selectedIdsArr];
  containerEl.innerHTML = '';
  containerEl.className = 'dropdown-search';

  const selectedContainer = document.createElement('div');
  selectedContainer.className = 'selected-items';
  containerEl.appendChild(selectedContainer);

  const input = document.createElement('input');
  input.type = 'text';
  input.placeholder = 'Поиск...';
  containerEl.appendChild(input);

  const list = document.createElement('div');
  list.className = 'dropdown-list';
  containerEl.appendChild(list);

  function renderSelected() {
    selectedContainer.innerHTML = selected.map(id => {
      const item = items.find(i => idsMatch(i.id, id));
      return `<span class="selected-item">${id} (${item?.name||item?.title||'?'}) <span class="remove" data-id="${strId(id)}">×</span></span>`;
    }).join('') + (selected.length === 0 ? `<span style="color:var(--text-dim);font-size:0.78rem;padding:0.2rem 0.5rem;">${placeholder}</span>` : '');
    selectedContainer.querySelectorAll('.remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        selected = selected.filter(id => !idsMatch(id, btn.dataset.id));
        renderSelected();
      });
    });
  }

  function filterList(search) {
    list.innerHTML = '';
    const filtered = items.filter(i =>
      strId(i.id).includes(search) ||
      (i.name||i.title||'').toLowerCase().includes(search.toLowerCase())
    );
    if (filtered.length === 0) {
      list.innerHTML = '<div class="dropdown-item no-results">Ничего не найдено</div>';
    } else {
      filtered.forEach(i => {
        const div = document.createElement('div');
        div.className = 'dropdown-item';
        div.textContent = `${i.id} — ${i.name||i.title}`;
        div.addEventListener('mousedown', (e) => {
          e.preventDefault();
          if (!selected.some(s => idsMatch(s, i.id))) {
            selected.push(i.id);
            renderSelected();
          }
          input.value = '';
          list.style.display = 'none';
        });
        list.appendChild(div);
      });
    }
  }

  renderSelected();

  selectedContainer.addEventListener('click', () => {
    filterList(input.value);
    list.style.display = list.style.display === 'block' ? 'none' : 'block';
    input.focus();
  });
  input.addEventListener('focus', () => { filterList(input.value); list.style.display = 'block'; });
  input.addEventListener('input', () => { filterList(input.value); list.style.display = 'block'; });
  input.addEventListener('blur', () => { setTimeout(() => { list.style.display = 'none'; }, 200); });
  input.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') { list.style.display = 'none'; input.blur(); }
  });

  containerEl._getSelected = () => selected;
  containerEl._getSelectedStr = () => selected.join(', ');
  containerEl._setSelected = (arr) => { selected = [...arr]; renderSelected(); };
  return containerEl;
}

