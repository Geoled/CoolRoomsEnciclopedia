function escapeHtml(str) { return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function sortArray(arr, key) {
  const a = [...arr];
  switch(key) {
    case 'id_asc': return a.sort((x,y) => (strId(x.id)).localeCompare(strId(y.id), undefined, {numeric:true}));
    case 'id_desc': return a.sort((x,y) => (strId(y.id)).localeCompare(strId(x.id), undefined, {numeric:true}));
    case 'name_asc': return a.sort((x,y) => (x.title||x.name||'').localeCompare(y.title||y.name||''));
    case 'name_desc': return a.sort((x,y) => (y.title||y.name||'').localeCompare(x.title||x.name||''));
    case 'class_asc': return a.sort((x,y) => (parseInt(x.cls)||0) - (parseInt(y.cls)||0));
    case 'class_desc': return a.sort((x,y) => (parseInt(y.cls)||0) - (parseInt(x.cls)||0));
    case 'date_asc': return a.sort((x,y) => (x.discoveredAt||'').localeCompare(y.discoveredAt||''));
    case 'date_desc': return a.sort((x,y) => (y.discoveredAt||'').localeCompare(x.discoveredAt||''));
    default: return a;
  }
}

