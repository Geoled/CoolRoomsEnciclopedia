function saveFormDraft() {
  if (!currentEditType) return;
  const draft = {
    id: document.getElementById('editId')?.value || '',
    title: document.getElementById('editTitle')?.value || '',
    cluster: document.getElementById('editCluster')?.value || '',
    cls: document.getElementById('editClass')?.value || '',
    tags: document.getElementById('editTags')?.value || '',
    desc: document.getElementById('editDesc')?.value || '',
    thumbnail: document.getElementById('editThumbnail')?.value || '',
    discoveredAt: document.getElementById('editDiscoveredAt')?.value || '',
    habitat: document.getElementById('editHabitat')?.value || '',
    behavior: document.getElementById('editBehavior')?.value || '',
    survival: document.getElementById('editSurvival')?.value || '',
    props: document.getElementById('editProps')?.value || '',
    effect: document.getElementById('editEffect')?.value || '',
    stats: {}
  };
  // Collect stats
  editContent.querySelectorAll('#statsGrid input[type="number"]').forEach(el => {
    const key = el.id.replace('edit_', '');
    draft.stats[key] = parseFloat(el.value) || 0;
  });
  // Collect dropdown selections
  if (editContent._dropdowns) {
    const dd = editContent._dropdowns;
    if (dd.entity) draft.ent = dd.entity._getSelected().map(strId);
    if (dd.food) draft.foodIds = dd.food._getSelected().map(strId);
    if (dd.item) draft.itemIds = dd.item._getSelected().map(strId);
    if (dd.in) draft.in = dd.in._getSelectedStr();
    if (dd.out) draft.out = dd.out._getSelectedStr();
  }
  localStorage.setItem('formDraft_' + currentEditType, JSON.stringify(draft));
}

async function saveEdit(type, obj) {
  const images = [];
  document.querySelectorAll('#imagesContainer .image-entry').forEach(e => {
    const u = e.querySelector('.image-url').value.trim();
    const d = e.querySelector('.image-desc').value.trim();
    if (u) images.push({ url: u, description: d });
  });

  let newId = document.getElementById('editId').value.trim();
  if (!newId) newId = String(getMaxId(data[type]) + 1);

  const newObj = {
    id: newId,
    cls: document.getElementById('editClass').value,
    tags: document.getElementById('editTags').value.split(',').map(s => s.trim()).filter(Boolean),
    stats: {},
    desc: document.getElementById('editDesc').value,
    discoveredAt: document.getElementById('editDiscoveredAt')?.value || new Date().toISOString().split('T')[0],
    thumbnail: document.getElementById('editThumbnail').value,
    images
  };

  if (type === 'levels') {
    newObj.title = document.getElementById('editTitle').value;
    newObj.cluster = document.getElementById('editCluster')?.value || '';
    newObj.stats = {
      safety: +document.getElementById('edit_safety')?.value || 3,
      stability: +document.getElementById('edit_stability')?.value || 3,
      entities: +document.getElementById('edit_entities')?.value || 3,
      resources: +document.getElementById('edit_resources')?.value || 3,
      mental: +document.getElementById('edit_mental')?.value || 3,
      navigation: +document.getElementById('edit_navigation')?.value || 3
    };
  } else {
    newObj.name = document.getElementById('editTitle').value;
  }

  if (type === 'entities') {
    newObj.stats = {
      danger: +document.getElementById('edit_danger')?.value || 3,
      frequency: +document.getElementById('edit_frequency')?.value || 3,
      intelligence: +document.getElementById('edit_intelligence')?.value || 3,
      aggression: +document.getElementById('edit_aggression')?.value || 3
    };
    newObj.habitat = document.getElementById('editHabitat')?.value || '';
    newObj.behavior = document.getElementById('editBehavior')?.value || '';
    newObj.survival = document.getElementById('editSurvival')?.value || '';
  }
  if (type === 'items') {
    newObj.stats = {
      weight: +document.getElementById('edit_weight')?.value || 3,
      rarity: +document.getElementById('edit_rarity')?.value || 3,
      usefulness: +document.getElementById('edit_usefulness')?.value || 3,
      durability: +document.getElementById('edit_durability')?.value || 3
    };
    newObj.props = document.getElementById('editProps')?.value || '';
  }
  if (type === 'foods') {
    newObj.stats = {
      calories: +document.getElementById('edit_calories')?.value || 500,
      availability: +document.getElementById('edit_availability')?.value || 5,
      taste: +document.getElementById('edit_taste')?.value || 3,
      shelfLife: +document.getElementById('edit_shelfLife')?.value || 7
    };
    newObj.effect = document.getElementById('editEffect')?.value || '';
  }

  // Dropdowns for levels
  if (type === 'levels' && editContent._dropdowns) {
    const dd = editContent._dropdowns;
    newObj.ent = dd.entity._getSelected().map(strId);
    newObj.foodIds = dd.food._getSelected().map(strId);
    newObj.itemIds = dd.item._getSelected().map(strId);
    newObj.in = dd.in._getSelectedStr();
    newObj.out = dd.out._getSelectedStr();
  }

  const filename = `${type}/${type}_${newObj.id}.json`;
  const loading = showLoading(editContent);
  const success = await commitFile(filename, newObj, obj?._sha);
  hideLoading(loading);

  if (success) {
    localStorage.removeItem('formDraft_' + type);
    if (obj) {
      const idx = data[type].findIndex(o => idsMatch(o.id, obj.id));
      if (idx !== -1) data[type][idx] = { ...newObj, _sha: obj._sha };
    } else {
      data[type].push(newObj);
    }
    editModal.classList.remove('active');
    document.body.style.overflow = '';
    currentEditType = null;
    toast(`"${newObj.title || newObj.name}" сохранён`, 'success');
    renderTree();
    renderContent();
  }
}

// ── Tree ───────────────────────────────────────
function renderTree() {
  if (currentSection === 'home') {
    tree.innerHTML = '<div style="padding:1rem;color:var(--text-dim);text-align:center;">Выберите раздел</div>';
    return;
  }
  const arr = getCurrentArray();

  if (currentSection === 'levels') {
    const clusters = {};
    arr.forEach(l => {
      const c = l.cluster || 'Без кластера';
      if (!clusters[c]) clusters[c] = [];
      clusters[c].push(l);
    });
    tree.innerHTML = '';
    Object.entries(clusters).forEach(([name, items]) => {
      const folder = document.createElement('div');
      folder.className = 'tree-item tree-folder open';
      folder.textContent = name;

      const childContainer = document.createElement('div');
      childContainer.className = 'tree-children';
      childContainer.style.maxHeight = '2000px';

      folder.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = folder.classList.contains('open');
        folder.classList.toggle('open');
        childContainer.style.maxHeight = isOpen ? '0px' : (items.length * 50 + 'px');
      });

      tree.appendChild(folder);
      tree.appendChild(childContainer);

      items.forEach(l => {
        const item = document.createElement('div');
        item.className = 'tree-item';
        item.style.paddingLeft = '2rem';
        item.innerHTML = `<span>${getClassIcon('levels', l.cls)}</span> <span>${l.title}</span>`;
        item.addEventListener('click', (e) => {
          e.stopPropagation();
          document.querySelectorAll('.tree-item').forEach(el => el.classList.remove('active'));
          item.classList.add('active');
          openView('levels', l.id);
        });
        childContainer.appendChild(item);
      });
    });
  } else {
    tree.innerHTML = '';
    arr.forEach(d => {
      const item = document.createElement('div');
      item.className = 'tree-item';
      item.innerHTML = `<span>${getClassIcon(currentSection, d.cls)}</span> <span>${d.title || d.name}</span>`;
      item.addEventListener('click', () => {
        document.querySelectorAll('.tree-item').forEach(el => el.classList.remove('active'));
        item.classList.add('active');
        openView(currentSection, d.id);
      });
      tree.appendChild(item);
    });
  }
}

// ── Section switching ──────────────────────────
async function switchSection(section) {
  currentSection = section;
  document.querySelectorAll('.tab-btn').forEach(b =>
    b.classList.toggle('active', b.dataset.tab === section)
  );
  breadcrumbs.innerHTML = section === 'home'
    ? 'Главная'
    : `<span onclick="window._switchSection('home')">Главная</span> › ${section==='levels'?'Уровни':section==='entities'?'Сущности':section==='items'?'Предметы':'Еда'}`;
  if (section !== 'home') {
    const loading = showLoading(contentArea);
    await loadSectionData(section);
    hideLoading(loading);
  }
  renderTree();
  renderContent();
}

// ── Export/Import ──────────────────────────────
function exportAllData() {
  const allData = { levels: data.levels, entities: data.entities, items: data.items, foods: data.foods };
  const blob = new Blob([JSON.stringify(allData, null, 2)], { type: 'application/json' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `gods_final_farewell_backup_${new Date().toISOString().split('T')[0]}.json`;
  a.click();
  URL.revokeObjectURL(url);
  toast('Экспорт завершён', 'success');
}

function importAllData() {
  const input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.onchange = async (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = async (ev) => {
      try {
        const imported = JSON.parse(ev.target.result);
        if (imported.levels && imported.entities && imported.items && imported.foods) {
          if (!confirm(`Импортировать ${imported.levels.length} уровней, ${imported.entities.length} сущностей, ${imported.items.length} предметов, ${imported.foods.length} еды? Текущие данные на GitHub будут перезаписаны.`)) return;
          const loading = showLoading(contentArea);
          let ok = true;
          for (const type of ['levels','entities','items','foods']) {
            for (const obj of imported[type]) {
              const filename = `${type}/${type}_${obj.id}.json`;
              const success = await commitFile(filename, obj);
              if (!success) { ok = false; break; }
            }
            if (!ok) break;
          }
          hideLoading(loading);
          if (ok) {
            await loadAllData();
            renderTree(); renderContent();
            toast('Импорт завершён!', 'success');
          }
        } else {
          toast('Неверный формат файла', 'error');
        }
      } catch(e) { toast('Ошибка чтения файла', 'error'); }
    };
    reader.readAsText(file);
  };
  input.click();
}

// ── Event Listeners ────────────────────────────
document.getElementById('settingsBtn').addEventListener('click', () => {
  document.getElementById('settingsOwner').value = API.owner() || '';
  document.getElementById('settingsRepo').value = API.repo() || '';
  document.getElementById('settingsToken').value = API.token() || '';
  document.getElementById('settingsModal').classList.add('active');
  document.body.style.overflow = 'hidden';
});
document.getElementById('closeSettingsBtn').addEventListener('click', () => {
  document.getElementById('settingsModal').classList.remove('active');
  document.body.style.overflow = '';
});
document.getElementById('saveSettingsBtn').addEventListener('click', () => {
  localStorage.setItem('gh_owner', document.getElementById('settingsOwner').value.trim());
  localStorage.setItem('gh_repo', document.getElementById('settingsRepo').value.trim());
  localStorage.setItem('gh_token', document.getElementById('settingsToken').value.trim());
  document.getElementById('settingsModal').classList.remove('active');
  document.body.style.overflow = '';
  toast('Настройки сохранены', 'success');
});

document.getElementById('luckyBtn').addEventListener('click', async () => {
  const all = [...data.levels, ...data.entities, ...data.items, ...data.foods];
  if (!all.length) { toast('База данных пуста', 'info'); return; }
  const randomObj = all[Math.floor(Math.random() * all.length)];
  const type = data.levels.includes(randomObj) ? 'levels'
    : data.entities.includes(randomObj) ? 'entities'
    : data.items.includes(randomObj) ? 'items' : 'foods';
  await switchSection(type);
  openView(type, randomObj.id);
});

document.querySelectorAll('.tab-btn').forEach(b =>
  b.addEventListener('click', () => switchSection(b.dataset.tab))
);

document.getElementById('refreshBtn').addEventListener('click', async () => {
  fileIndexCache = {};
  const loading = showLoading(contentArea);
  await loadAllData();
  hideLoading(loading);
  renderTree(); renderContent();
  toast('Данные обновлены', 'info');
});

document.getElementById('addBtn').addEventListener('click', () => {
  if (currentSection === 'home') { toast('Перейдите в нужный раздел', 'info'); return; }
  openEditModal(currentSection);
});

// Modal close on backdrop click
viewModal.addEventListener('click', (e) => {
  if (e.target === viewModal) closeView();
});
editModal.addEventListener('click', (e) => {
  if (e.target === editModal) closeEdit();
});
document.getElementById('settingsModal').addEventListener('click', (e) => {
  if (e.target === document.getElementById('settingsModal')) {
    document.getElementById('settingsModal').classList.remove('active');
    document.body.style.overflow = '';
  }
});

// Lightbox
lightbox.addEventListener('click', () => {
  lightbox.classList.remove('active');
});

// Mobile menu
const mobileMenuBtn = document.getElementById('mobileMenuBtn');
const sidebar = document.getElementById('sidebar');
mobileMenuBtn.addEventListener('click', () => {
  sidebar.classList.toggle('open');
});
// Close sidebar when clicking outside on mobile
document.addEventListener('click', (e) => {
  if (window.innerWidth <= 768 && !sidebar.contains(e.target) && e.target !== mobileMenuBtn && !mobileMenuBtn.contains(e.target)) {
    sidebar.classList.remove('open');
  }
});

// Keyboard shortcuts
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape') {
    if (lightbox.classList.contains('active')) lightbox.classList.remove('active');
    else if (viewModal.classList.contains('active')) closeView();
    else if (editModal.classList.contains('active')) closeEdit();
    else if (document.getElementById('settingsModal').classList.contains('active')) {
      document.getElementById('settingsModal').classList.remove('active');
      document.body.style.overflow = '';
    }
  }
});

// Expose to window for onclick handlers
window._switchSection = switchSection;
window.openView = openView;

// ── Init ───────────────────────────────────────
(async () => {
  await loadAllData();
  renderTree();
  renderContent();
})();

})();
</script>
